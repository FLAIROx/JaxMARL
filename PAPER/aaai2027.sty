\skip\footins 9pt plus 4pt minus 2pt
\def\footnoterule{\kern-3pt \hrule width 5pc \kern 2.6pt }
\setcounter{footnote}{0}
%
% FOOTNOTE-AREA INSERT REGISTERS
% Two dedicated insert classes ensure the first-column footnote area always
% appears in the correct order:
%   1. body footnotes  (from abstract / introduction text, arabic numerals)
%   2. title footnotes (from \equalcontrib, \corresponding, \thanks, symbols)
%   3. copyright notice
% count=1000 gives the same page-cost weight as \footins so TeX reserves
% the correct amount of column space for each register.
\newinsert\aaai@thanksins%
\count\aaai@thanksins=1000%
\dimen\aaai@thanksins=\maxdimen%
\skip\aaai@thanksins=\skip\footins%
%
\newinsert\aaai@copyrightins%
\count\aaai@copyrightins=1000%
\dimen\aaai@copyrightins=\maxdimen%
\skip\aaai@copyrightins=\skip\footins%
%
% Patch \@makecol to assemble: body footnotes, then title thanks, then copyright.
% Budget accounting: \skip\aaai@thanksins and \skip\aaai@copyrightins are each set to
% \skip\footins (the worst case: opening the footnote area with rule + gap).  When the
% area is already open (body footnotes present, or thanks already appended) we only add
% 4pt physically; the ~5pt deficit is silently absorbed by the infinite stretch glue that
% \flushbottom places between paragraphs.  This keeps the page height exact in the
% worst case (no body footnotes) and produces no overfull warnings in any case.
\newif\ifaaai@hasfootnotes
\let\aaai@orig@makecol\@makecol
\def\@makecol{%
  % Merge title/thanks footnotes and copyright into \footins so the
  % standard \@makecol emits a single rule and gap for the whole area.
  % TeX has already budgeted \@colht for all three registers (count=1000).
  \ifvoid\aaai@thanksins\else
    \setbox\footins\vbox{%
      \boxmaxdepth\@maxdepth
      \ifvoid\footins\else\unvbox\footins\fi
      \unvbox\aaai@thanksins}%
  \fi
  \ifvoid\aaai@copyrightins\else
    \setbox\footins\vbox{%
      \boxmaxdepth\@maxdepth
      \ifvoid\footins\else\unvbox\footins\fi
      \vskip 2pt
      \unvbox\aaai@copyrightins}%
  \fi
  \aaai@orig@makecol
}
