%
% ENGINE GUARD — this style requires PDFLaTeX.
% Attempting to compile with XeLaTeX or LuaLaTeX will stop here with a clear
% error instead of producing silently broken output.
\RequirePackage{iftex}
\RequirePDFTeX
%
% FONT ENCODING — T1 is the correct encoding for PDFLaTeX with Type 1 fonts.
% It enables proper hyphenation of words with accented characters and correct
% copy/search of accented text in the generated PDF.
\RequirePackage[T1]{fontenc}
% SERIF TEXT FONT — newtxtext provides a Times-like text face that is
% PDFLaTeX-native, Type 1-compatible, and more carefully maintained than
% the legacy times package. Authors must not load \usepackage{times}
% or any competing text-font package in their document preamble.
\RequirePackage{newtxtext}
% SANS-SERIF FONT — helvet provides Helvetica for sans-serif text.
\RequirePackage{helvet}
% MONOSPACED FONT — courier provides Courier for typewriter/code text.
\RequirePackage{courier}
