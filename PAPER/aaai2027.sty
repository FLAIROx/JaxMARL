% The article class's \endthebibliography normally runs an empty-list warning
% check (\@noitemerr) before closing the list. We bypass that check by pointing
% directly to \endlist, preventing spurious warnings when natbib (or the AAAI
% bibliography machinery) regenerates the environment.
\let\endthebibliography=\endlist
